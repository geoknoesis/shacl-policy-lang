@prefix shpl: <https://w3id.org/shacl-policy-language#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix cred: <https://www.w3.org/2018/credentials#> .
@prefix ex:   <http://example.com/ns#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

ex:StaffCred a cred:VerifiableCredential ;
  cred:issuer <did:example:hr> ;
  cred:credentialSubject [
    cred:id <did:example:carol> ;
    ex:role "Staff"
  ] .

ex:Request_Staff a shpl:AccessRequest ;
  shpl:agent <did:example:carol> ;
  shpl:action odrl:read ;
  shpl:target ex:Doc ;
  shpl:credential ex:StaffCred  .
